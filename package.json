{
  "name": "march-hare",
  "version": "0.13.4",
  "type": "module",
  "license": "MIT",
  "packageManager": "yarn@1.22.22",
  "main": "./dist/march-hare.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mh": "./dist/cli/bin/mh.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/march-hare.js",
      "require": "./dist/march-hare.umd.cjs"
    }
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "change-case": "^5.4.4",
    "ejs": "^3.1.10",
    "eventemitter3": "^5.0.4",
    "figlet": "^1.7.0",
    "find-up": "^8.0.0",
    "gray-matter": "^4.0.3",
    "immertation": "^0.1.29",
    "kleur": "^4.1.5",
    "tinyglobby": "^0.2.17"
  },
  "peerDependencies": {
    "@mobily/ts-belt": "^3.0.0",
    "immer": "^10.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "resolutions": {
    "vitest/vite": "^7.3.1"
  },
  "files": [
    "dist",
    "src/cli/README.md"
  ],
  "scripts": {
    "build": "vite build && npm run build:cli",
    "build:cli": "tsc -p tsconfig.cli.json && rm -rf dist/cli/templates && cp -R src/cli/templates dist/cli/templates && chmod +x dist/cli/bin/mh.js",
    "build:example": "vite build --mode example --outDir dist-example --base /MarchHare/ && mv dist-example/src/example/index.html dist-example/index.html && rm -rf dist-example/src",
    "dev": "vite",
    "preview": "vite preview",
    "release": "make checks",
    "prepare": "husky"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@emotion/css": "^11.13.5",
    "@eslint/js": "^9.39.3",
    "@faker-js/faker": "^10.3.0",
    "@feature-sliced/eslint-config": "^0.1.1",
    "@jest/globals": "^30.2.0",
    "@js-temporal/polyfill": "^0.5.1",
    "@mobily/ts-belt": "4.0.0-rc.5",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dom-navigation": "^1.0.7",
    "@types/ejs": "^3.1.5",
    "@types/lodash": "^4.17.23",
    "@types/ms": "^2.1.0",
    "@types/ramda": "^0.31.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/traverse": "^0.6.37",
    "@vitejs/plugin-react": "^5.1.4",
    "antd": "^6.3.0",
    "commit-and-tag-version": "^12.6.1",
    "dayjs": "^1.11.19",
    "dexie": "^4.3.0",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-fp": "^2.3.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "fslint": "^1.1.0",
    "get-port-cli": "^3.0.0",
    "globals": "^17.3.0",
    "happy-dom": "^20.6.1",
    "husky": "^9.1.7",
    "immer": "^11.1.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^28.1.0",
    "ky": "^2.0.2",
    "lodash": "^4.17.23",
    "lucide-react": "^0.564.0",
    "madge": "^8.0.0",
    "ms": "2",
    "prettier": "^3.8.1",
    "ramda": "^0.32.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-flip-numbers": "^3.0.9",
    "react-router-dom": "^7.13.0",
    "react-test-renderer": "^19.2.4",
    "react-wayfinder": "^0.1.4",
    "rollup-plugin-visualizer": "^6.0.5",
